  10          /**
  11           * @brief LED显示函数
  12           * @param ucLed 一个指向8元素数组的指针，数组每个元素为0或1，分别对应8个LED的灭和亮。
  13           * 例如 ucLed[0] 控制 LED1, ucLed[7] 控制 LED8。
  14           */
  15          void Led_Disp(unsigned char *ucLed)
  16          {
  17   1        unsigned char temp; // 用于P2口操作的临时变量
  18   1      
  19   1        // 1. 将8个独立的0/1值合并成一个8位的字节(temp_1)
  20   1        //    例如，如果ucLed = {1,0,1,0,0,0,0,0}, temp_1 将变为 00000101b = 0x05
  21   1        temp_1 = 0x00; // 先清零
  22   1        temp_1 = (ucLed[0] << 0) | (ucLed[1] << 1) | (ucLed[2] << 2) | (ucLed[3] << 3) |
  23   1             (ucLed[4] << 4) | (ucLed[5] << 5) | (ucLed[6] << 6) | (ucLed[7] << 7);
  24   1      
  25   1        // 2. 状态改变检测：只有当期望的LED状态与上一次设置的状态不同时，才执行硬件操作
  26   1        if (temp_1 != temp_1_old)
  27   1        {
  28   2          // 3. 更新硬件
  29   2          // P0口写入temp_1的反码。因为LED是共阳极连接，低电平(0)点亮，高电平(1)熄灭。
  30   2          // 例如，要点亮LED1(ucLed[0]=1), temp_1的bit0为1, ~temp_1的bit0则为0，输出低电平点亮LED。
  31   2          P0 = ~temp_1;
  32   2      
  33   2          // 使用138译码器选择LED外设组（Y4输出，地址100）
  34   2          temp = P2 & 0x1f; // 保留P2低5位
  35   2          temp = temp | 0x80; // 设置P2高3位为100
  36   2          P2 = temp;      // 选中LED锁存器
  37   2          temp = P2 & 0x1f; // 恢复P2高3位为000
  38   2          P2 = temp;      // 取消选择，完成数据锁存
  39   2      
  40   2          // 4. 更新状态缓存
  41   2          temp_1_old = temp_1;
  42   2        }
  43   1      }
  44          
  45          
  46          // --- 蜂鸣器、继电器、电机 相关全局变量 ---
  47          // 这三个外设通常连接在同一个锁存器上，由138译码器的同一个输出（Y5）控制。
  48          // 因此，它们的状态被合并在同一个字节(temp_2)里进行管理。
  49          idata unsigned char temp_2 = 0x00;
  50          idata unsigned char temp_2_old = 0xff;
  51          
  52          /**
  53           * @brief 控制继电器
  54           * @param enable bit类型的参数，1 为吸合，0 为断开
C51 COMPILER V9.60.7.0   LED                                                               03/27/2026 20:19:40 PAGE 2   

  55           * @note  此函数逻辑与Beep完全相同，只是操作的位不同。
  56           */
  57          void Relay(bit enable)
  58          {
  59   1        unsigned char temp;
  60   1      
  61   1        // 继电器由 bit 4 (0x10 = 0001 0000b) 控制
  62   1        if (enable)
  63   1          temp_2 |= 0x10;
  64   1        else
  65   1          temp_2 &= (~0x10);
  66   1      
  67   1        if (temp_2 != temp_2_old)
  68   1        {
  69   2          P0 = temp_2;
  70   2      
  71   2          // 同样选择Y5外设组
  72   2          temp = P2 & 0x1f;
  73   2          temp = temp | 0xa0;
  74   2          P2 = temp;
  75   2          temp = P2 & 0x1f;
  76   2          P2 = temp;
  77   2      
  78   2          temp_2_old = temp_2;
  79   2        }
