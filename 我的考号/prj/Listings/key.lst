  45   1          if(P33==0)temp=4;  // 检测第四列(P3.3)，如果为低电平，说明S4键被按下。
  46   1          
  47   1          // --- 扫描第二行 (由 P4.2 控制) ---
  48   1          // 恢复所有行线为高电平，结束上一行的扫描。
  49   1          P44=1;P42=1;P35=1;//P34=1;
  50   1          
  51   1          // 再次进行串口冲突检测
  52   1          if(P30==0)return 0; 
  53   1          
  54   1          // 核心操作：将第二行线(P4.2)拉低。
