  39   1          
  40   1          // 核心操作：将第一行线(P4.4)拉低，其他行线保持高电平。
  41   1          P44=0;P42=1;P35=1;//P34=1;
  42   1          if(P30==0)temp=7;  // 检测第一列(P3.0)，如果为低电平，说明S7键被按下。
