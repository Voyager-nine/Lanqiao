 504              {Seg_Proc, 20, 0},         // 数码管任务，每20ms
 505              {Get_Temperature, 300, 0}, // 获取温度任务，每300ms
 506              {AD_DA, 150, 0},           // AD/DA任务，每150ms
 507              {Get_Distance, 120, 0},    // 获取距离任务，每120ms
