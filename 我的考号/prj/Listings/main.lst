 423          /**
 424           * @brief 定时器1初始化函数
 425           * 配置为1ms中断的定时器，作为系统的心跳。
 426           */
 427          void Timer1_Init(void) // 1毫秒@12.000MHz
 428          {
 429   1          AUXR &= 0xBF; // 定时器时钟12T模式
 430   1          TMOD &= 0x0F; // 设置定时器模式 (清空T1的设置)
 431   1          TL1 = 0x18;   // 设置定时初始值 (65536-1000) -> FC18H
 432   1          TH1 = 0xFC;   // 设置定时初始值
 433   1          TF1 = 0;      // 清除TF1溢出标志
 434   1          TR1 = 1;      // 定时器1开始计时
 435   1          ET1 = 1;      // 使能定时器1中断
 436   1          EA = 1;       // 开启总中断
 437   1      }
