  15          /**
  16           * @brief 重写标准库的putchar函数
  17           * @param ch 要通过串口发送的单个字符
  18           * @return char 返回已发送的字符
  19           * @note  在Keil C51环境下，通过重写此函数，可以使printf函数的内容
  20           * 自动通过串口1发送出去，极大地方便了调试。
  21           */
  22          extern char putchar (char ch)
  23          {
  24   1          // SBUF是串行数据缓冲寄存器。向它写入数据即启动一次发送。
  25   1          SBUF = ch;
  26   1          
  27   1          // TI是SCON寄存器中的发送中断标志位。
  28   1          // 当一个字节的数据被完整发送出去后，硬件会自动将TI置1。
  29   1          // 此循环通过不断查询TI位的状态，来等待发送完成。这是一种“忙等”或“查询”方式。
  30   1          while(TI == 0)
  31   1              ;
  32   1          
  33   1          // TI标志位必须由软件清零。
  34   1          // 将TI清零，为下一次发送做准备。
  35   1          TI = 0;
  36   1          
  37   1          // 按照标准函数定义，返回发送的字符。
  38   1          return ch;
  39   1      }


